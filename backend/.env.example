# Backend environment variables
# URL of the frontend deployed on Vercel (no trailing slash)
FRONTEND_URL=https://YOUR-FRONTEND-URL.vercel.app

# Google Custom Search API (optional but recommended for better web data)
GOOGLE_API_KEY=sua_chave_aqui
GOOGLE_CX=seu_cx_aqui

# Bing Search API (alternative/alongside Google)
BING_API_KEY=sua_chave_aqui

# Internal settings
COMPLETENESS_THRESHOLD=0.3
CACHE_TTL_SECONDS=60
PLAYWRIGHT_HEADLESS=true

# Render injects this automatically; kept here only for local reference
# PORT=8000
