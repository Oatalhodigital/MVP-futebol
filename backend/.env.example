# Backend environment variables
# URL of the frontend deployed on Vercel (no trailing slash)
FRONTEND_URL=https://YOUR-FRONTEND-URL.vercel.app

# Google Custom Search / Bing Search API (optional)
# The system now works 100% without paid API keys, using DuckDuckGo/Google
# HTML search and free public APIs. Configure these only if you want an
# extra, potentially higher-quality fallback source.
# GOOGLE_API_KEY=sua_chave_aqui
# GOOGLE_CX=seu_cx_aqui
# BING_API_KEY=sua_chave_aqui

# Optional path to a custom team aliases JSON file
# TEAM_ALIASES_PATH=app/data/team_aliases.json

# Internal settings
COMPLETENESS_THRESHOLD=0.3
CACHE_TTL_SECONDS=60
PLAYWRIGHT_HEADLESS=true

# Render injects this automatically; kept here only for local reference
# PORT=8000
